# ============================================
# 飞书 Gateway 桥接服务 - 环境变量配置
# ============================================
# 复制此文件为 .env 并填入真实值

# 飞书应用配置
FEISHU_APP_ID=cli_aabc283c75f89cd2
FEISHU_APP_SECRET=your_app_secret_here

# 飞书事件订阅 Verification Token
FEISHU_VERIFICATION_TOKEN=your_verification_token_here

# 服务端口
PORT=3000

# CodeBuddy CLI 路径
CODEBUDDY_CLI_PATH=/root/.nvm/versions/node/v22.13.0/bin/codebuddy

# Gateway 模式 (remote-control)
GATEWAY_MODE=remote-control

# 日志级别: debug | info | warn | error
LOG_LEVEL=info
